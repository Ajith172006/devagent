# Server
PORT=3000

# SQLite database file (created automatically on first run)
DATABASE_PATH=devagent.sqlite

# Anthropic API key — required for /ai/debug and /ai/explain
ANTHROPIC_API_KEY=

# Model used for AI debugging / code explanations
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional GitHub personal access token — raises the GitHub API
# rate limit from 60 to 5000 requests/hour. Not required for
# public profile/repo lookups.
GITHUB_TOKEN=
