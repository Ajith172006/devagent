# Server
PORT=3000

# SQLite database file (created automatically on first run)
DATABASE_PATH=devagent.sqlite

# Admin panel secret — required to access /api/admin/*
# Set any strong random string, e.g: openssl rand -hex 32
ADMIN_SECRET=im_admin

# Google Gemini API key — required for /ai/debug and /ai/explain
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AQ.Ab8RN6L3uK8wEbZGEjF1xoN9sHtJNkaJ6auauxyVXxTnzrjlgAcd

# Gemini model to use for AI features (default: gemini-2.5-flash)
# Other options: gemini-2.0-flash, gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Optional GitHub personal access token — raises the GitHub API
# rate limit from 60 to 5000 requests/hour. Not required for
# public profile/repo lookups.
GITHUB_TOKEN=

# Firebase Project ID (optional: defaults to devagent-c0aaf)
# Wires token validation with the respective Firebase authentication project
FIREBASE_PROJECT_ID=devagent-c0aaf

# Allowed CORS Origins (optional: comma-separated list, defaults to localhost:5173/5174)
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174

